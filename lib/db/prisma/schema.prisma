generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

model Admin {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// --- RAW SOURCE DATA ---
model BronzeRedditSubmission {
  id              String   @id @default(cuid()) 
  redditId        String   @unique
  title           String
  selftext        String?
  author          String?
  score           Int      @default(0)
  url             String?
  permalink       String?
  numComments     Int      @default(0)
  charCount       Int?
  postedAt        DateTime
  
  // Pipeline State
  isProcessed     Boolean  @default(false)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  comments        BronzeRedditComment[]
  mentions        SilverProductMention[]
  aiSpends        AiSpend[]

  @@index([score(sort: Desc)])
  @@index([postedAt(sort: Desc)])
}

model BronzeRedditComment {
  id              String   @id @default(cuid())
  redditId        String   @unique
  submissionId    String
  linkId          String
  parentId        String?
  body            String
  author          String?
  score           Int      @default(0)
  postedAt        DateTime
  
  // Pipeline State
  isProcessed     Boolean  @default(false)

  submission      BronzeRedditSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  mentions        SilverProductMention[]

  @@index([submissionId])
}

// --- GOLD LAYER (CANONICAL ENTITIES) ---

model GoldDepartment {
  id              String   @id @default(cuid())
  canonicalName   String   @unique
  
  productLines    GoldProductLine[]
  products        GoldProduct[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model GoldCategory {
  id              String   @id @default(cuid())
  canonicalName   String   @unique
  embedding       Unsupported("vector(1024)")?
  
  productLines    GoldProductLine[]
  products        GoldProduct[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model SilverCategoryIdea {
  id                String   @id @default(cuid())
  goldProductLineId String?
  goldProductId     String?
  rawName           String
  
  isProcessed       Boolean  @default(false)
  
  goldProductLine   GoldProductLine? @relation(fields: [goldProductLineId], references: [id], onDelete: Cascade)
  goldProduct       GoldProduct?     @relation(fields: [goldProductId], references: [id], onDelete: Cascade)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
model GoldBrand {
  id              String   @id @default(cuid())
  canonicalName   String   @unique
  
  // Aggregated fields
  avgSentiment    Float    @default(0) // Scaled
  mentionCount    Int      @default(0)
  
  // Pipeline State
  isTitled        Boolean  @default(false)
  
  // The Embedding used for KNN distance
  embedding       Unsupported("vector(1024)")?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  productLines    GoldProductLine[]
  products        GoldProduct[]
  mentions        SilverProductMention[]
  affiliateLinks  AffiliateLink[]
}

model GoldProductLine {
  id              String   @id @default(cuid())
  goldBrandId     String
  canonicalName   String
  brand           String
  
  // Aggregated fields
  avgSentiment    Float    @default(0) // Scaled
  mentionCount    Int      @default(0)
  
  // Pipeline State
  isTitled        Boolean  @default(false)
  
  // The Embedding used for KNN distance
  embedding       Unsupported("vector(1024)")?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  goldDepartmentId String?
  goldDepartment   GoldDepartment? @relation(fields: [goldDepartmentId], references: [id], onDelete: SetNull)
  categories       GoldCategory[]
  categoryIdeas    SilverCategoryIdea[]

  goldBrand       GoldBrand @relation(fields: [goldBrandId], references: [id], onDelete: Cascade)
  products        GoldProduct[]
  mentions        SilverProductMention[]
  affiliateLinks  AffiliateLink[]
}

model GoldProduct {
  id                String   @id @default(cuid())
  goldBrandId       String
  goldProductLineId String?
  canonicalName     String
  brand             String
  
  // Aggregated fields
  avgSentiment      Float    @default(0) // Scaled
  mentionCount      Int      @default(0)
  
  // Pipeline State
  isTitled          Boolean  @default(false)
  isHierarchyAnalyzed Boolean @default(false)
  
  // The Embedding used for KNN distance
  embedding         Unsupported("vector(1024)")?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  goldDepartmentId  String?
  goldDepartment    GoldDepartment? @relation(fields: [goldDepartmentId], references: [id], onDelete: SetNull)
  categories        GoldCategory[]
  categoryIdeas     SilverCategoryIdea[]

  goldBrand         GoldBrand @relation(fields: [goldBrandId], references: [id], onDelete: Cascade)
  goldProductLine   GoldProductLine? @relation(fields: [goldProductLineId], references: [id], onDelete: SetNull)
  mentions          SilverProductMention[]
  affiliateLinks  AffiliateLink[]
}

// --- SILVER LAYER (EXTRACTED PRIMITIVES) ---
model SilverProductMention {
  id                String   @id @default(cuid())
  submissionId      String?
  commentId         String?
  goldBrandId       String?
  goldProductLineId String?
  goldProductId     String?

  // The Raw Identity Data
  brand             String
  productName       String
  quote             String
  specificityLevel  String    @default("UNKNOWN") // EXACT_MODEL, PRODUCT_LINE, BRAND_ONLY
  
  // Cost Per Use (CPU) Primitives //
  acquiredPrice           Float?   // e.g. 200.00
  ownershipDurationMonths Int?     // "10 years" -> 120
  usageFrequency          String?  // DAILY, WEEKLY, MONTHLY, SEASONAL, RARELY
  
  // Radar Chart - POSITIVE, NEUTRAL, NEGATIVE
  durability      String?
  repairability   String?
  maintenance     String?
  warranty        String?
  value           String?
  
  // Authenticity Signals
  sentiment       String     // POSITIVE, NEUTRAL, NEGATIVE
  flawOrCaveat    String?    // e.g. "Runs very narrow"

  // The Embedding representation of [Brand + Product Name + Category]
  embedding         Unsupported("vector(1024)")?

  submission        BronzeRedditSubmission? @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  comment           BronzeRedditComment?    @relation(fields: [commentId], references: [id], onDelete: Cascade)
  goldBrand         GoldBrand?              @relation(fields: [goldBrandId], references: [id], onDelete: Cascade)
  goldProductLine   GoldProductLine?        @relation(fields: [goldProductLineId], references: [id], onDelete: Cascade)
  goldProduct       GoldProduct?            @relation(fields: [goldProductId], references: [id], onDelete: Cascade)
}

// --- AI TRACKING LAYER ---
model AiSpend {
  id              String   @id @default(cuid())
  submissionId    String?

  model           String   // e.g. "gemini-3-flash-preview"
  jobName         String   // The pipeline phase that incurred the cost

  promptTokens    Int      @default(0)
  cachedTokens    Int      @default(0)
  responseTokens  Int      @default(0)
  thinkingTokens  Int      @default(0)
  totalTokens     Int      @default(0)

  costInUsd       Float

  createdAt       DateTime @default(now())
  
  submission      BronzeRedditSubmission? @relation(fields: [submissionId], references: [id], onDelete: Cascade)
}

// --- MONETIZATION LAYER ---
model AffiliateLink {
  id                String   @id @default(cuid())
  provider          String   // e.g., "AMAZON", "SHAREASALE", "AVANTLINK"
  url               String   // The explicit tracking URL or ASIN
  isVerified        Boolean  @default(false)
  
  // Relations
  goldBrandId       String?
  goldProductLineId String?
  goldProductId     String?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  goldBrand         GoldBrand?       @relation(fields: [goldBrandId], references: [id], onDelete: Cascade)
  goldProductLine   GoldProductLine? @relation(fields: [goldProductLineId], references: [id], onDelete: Cascade)
  goldProduct       GoldProduct?     @relation(fields: [goldProductId], references: [id], onDelete: Cascade)
}
