{
  "name": "@mono/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --clear-screen=false src/index.ts",
    "clean": "rm -rf dist",
    "build": "dotenv -e ../../.env -- tsc -p tsconfig.build.json",
    "start": "dotenv -e ../../.env -- node dist/index.js",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "lint": "eslint",
    "test": "vitest run",
    "test:unit": "vitest run",
    "eval": "npm run eval -w @mono/ai",
    "ingest:reddit": "dotenv -e ../../.env -- tsx src/scripts/ingest.ts",
    "ingest:vectors": "dotenv -e ../../.env -- tsx src/scripts/vector-resolution.ts",
    "cost:estimate": "dotenv -e ../../.env -- tsx src/scripts/cost-estimator.ts",
    "inspect:short": "dotenv -e ../../.env -- tsx src/scripts/view-short-posts.ts"
  },
  "dependencies": {
    "@google/genai": "^1.48.0",
    "@hocuspocus/provider": "^2.15.3",
    "@mono/db": "*",
    "@mono/emails": "^0.1.0",
    "@mono/storage": "^0.1.0",
    "@react-email/components": "^1.0.11",
    "@t3-oss/env-core": "^0.13.11",
    "@xenova/transformers": "^2.17.2",
    "bullmq": "^5.73.0",
    "discord.js": "^14.26.2",
    "dotenv": "^17.4.1",
    "ioredis": "^5.10.1",
    "nodemailer": "^6.10.1",
    "p-retry": "^7.1.1",
    "playwright": "^1.59.1",
    "posthog-node": "^5.28.11",
    "prosemirror-model": "^1.25.4",
    "prosemirror-state": "^1.4.4",
    "prosemirror-view": "^1.41.8",
    "resend": "^6.10.0",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "ws": "^8.20.0",
    "y-prosemirror": "^1.3.7",
    "yjs": "^13.6.30",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@mono/eslint-config": "*",
    "@types/nodemailer": "^7.0.11",
    "@types/ws": "^8.18.1"
  }
}
