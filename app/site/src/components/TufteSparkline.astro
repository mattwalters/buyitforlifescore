---
import * as d3 from 'd3';

export interface Props {
  data: { year: number; score: number }[];
  color?: string;
  width?: number;
  height?: number;
}

const { data, color = '#64748b', width = 120, height = 32 } = Astro.props;

// If we don't have enough data points to plot a line, render an empty state or simple text.
if (!data || data.length < 2) {
  return null;
}

const sortedData = [...data].sort((a, b) => a.year - b.year);

// Force X boundaries based on the data provided
const xMin = d3.min(sortedData, d => d.year) ?? new Date().getFullYear();
const xMax = d3.max(sortedData, d => d.year) ?? new Date().getFullYear();

// Provide minimal horizontal padding to prevent stroke clipping
const xScale = d3.scaleLinear()
  .domain([xMin, xMax])
  .range([4, width - 4]);

// Y domain is always 0 to 100 for BIFL sentiment
const yScale = d3.scaleLinear()
  .domain([0, 100])
  .range([height - 4, 4]);

const lineGenerator = d3.line<{year: number, score: number}>()
  .x(d => xScale(d.year))
  .y(d => yScale(d.score))
  .curve(d3.curveMonotoneX);

const pathD = lineGenerator(sortedData);
---

<div class="tufte-sparkline" style={`width: ${width}px; height: ${height}px; display: inline-block; vertical-align: middle;`} title="Overall Quality Trajectory over time">
  {pathD && (
    <svg viewBox={`0 0 ${width} ${height}`} width="100%" height="100%" aria-hidden="true" style="overflow: visible;">
      {/* 50pt Reference Baseline */}
      <line 
         x1="0" 
         x2={width} 
         y1={yScale(50)} 
         y2={yScale(50)} 
         stroke="#e2e8f0" 
         stroke-width="1" 
         stroke-dasharray="2 2" 
      />
      
      {/* Target Trajectory */}
      <path 
         d={pathD} 
         fill="none" 
         stroke={color} 
         stroke-width="2" 
         stroke-linecap="round" 
         stroke-linejoin="round"
      />

      {/* Origin Dot (Faded) */}
      <circle 
         cx={xScale(sortedData[0].year)} 
         cy={yScale(sortedData[0].score)} 
         r="2" 
         fill={color} 
         opacity="0.4"
      />

      {/* Culminating Dot */}
      <circle 
         cx={xScale(sortedData[sortedData.length - 1].year)} 
         cy={yScale(sortedData[sortedData.length - 1].score)} 
         r="3" 
         fill={color} 
      />
    </svg>
  )}
</div>
