---
import { prisma as db } from "@mono/db";
import { slugify } from "../../utils/slugify";

import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const departments = await db.goldDepartment.findMany({
    include: { 
      productLines: {
        include: { goldBrand: true },
        orderBy: { mentionCount: 'desc' }
      }
    }
  });

  return departments.map(dept => {
    return {
      params: { department: slugify(dept.canonicalName) },
      props: { department: dept },
    };
  });
}

const { department } = Astro.props;
---

<BaseLayout title={`${department.canonicalName}`}>
  <nav class="breadcrumbs">
    <a href="/">Home</a> &gt; {department.canonicalName}
  </nav>

  <header>
    <h1>Department: {department.canonicalName}</h1>
    <p>A master index of BIFL product lines managed within this department.</p>
  </header>
  
  <section>
    <h2>Top Associated Product Lines</h2>
    <div class="data-grid">
      {department.productLines.map((line: any) => (
        <a href={`/product/${slugify(line.goldBrand.canonicalName)}/${slugify(line.canonicalName)}`} class="bifl-card" style="text-decoration: none;">
          <h3 style="margin-top: 0; color: var(--bifl-charcoal);">{line.goldBrand.canonicalName} {line.canonicalName}</h3>
          <span class="score-badge">{line.mentionCount} Mentions</span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
