---
import { prisma as db } from "@mono/db";
import { slugify } from "../../../../utils/slugify";

import BaseLayout from '../../../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const models = await db.goldProduct.findMany({
    include: {
      goldBrand: true,
      goldProductLine: {
        include: { products: true, categories: true }
      },
      mentions: true
    }
  });

  return models.map(model => {
    // Basic rollups for the frontend
    const validPrices = model.mentions.map(m => m.acquiredPrice).filter(p => p !== null) as number[];
    const avgPrice = validPrices.length ? (validPrices.reduce((a,b) => a+b, 0) / validPrices.length).toFixed(2) : null;
    
    const validDurations = model.mentions.map(m => m.ownershipDurationMonths).filter(p => p !== null) as number[];
    const avgDuration = validDurations.length ? (validDurations.reduce((a,b) => a+b, 0) / validDurations.length / 12).toFixed(1) : null;

    const caveats = model.mentions.map(m => m.flawOrCaveat).filter(f => f && f.length > 5).slice(0, 3);
    const quotes = model.mentions.map(m => m.quote).filter(q => q && q.length > 5).slice(0, 3);

    const lineSlug = model.goldProductLine ? slugify(model.goldProductLine.canonicalName) : "standalone";
    const lineDisplay = model.goldProductLine ? model.goldProductLine.canonicalName : "Standalone Gear";
    // Only resolve siblings if it belongs to a line
    const siblingModels = model.goldProductLine ? model.goldProductLine.products.filter(p => p.id !== model.id) : [];

    // Calculate normalized 100-pt rating for Schema.org
    const schemaRating = Math.min(100, Math.max(10, Math.round((model.avgSentiment / 1) * 100)));

    const schemaData = {
      "@context": "https://schema.org/",
      "@type": "Product",
      "name": model.canonicalName,
      "brand": {
        "@type": "Brand",
        "name": model.goldBrand.canonicalName
      },
      "aggregateRating": model.mentionCount > 0 ? {
        "@type": "AggregateRating",
        "ratingValue": schemaRating.toString(),
        "bestRating": "100",
        "ratingCount": model.mentionCount.toString()
      } : undefined
    };

    return {
      params: { 
        brand: slugify(model.goldBrand.canonicalName),
        line: lineSlug,
        model: slugify(model.canonicalName)
      },
      props: { 
        model,
        avgPrice,
        avgDuration,
        caveats,
        quotes,
        siblingModels,
        lineDisplay,
        lineSlug,
        schemaData
      },
    };
  });
}

const { model, siblingModels, avgPrice, avgDuration, caveats, quotes, lineDisplay, lineSlug, schemaData } = Astro.props;
---

<BaseLayout title={`${model.goldBrand.canonicalName} ${model.canonicalName} Review`} schemaData={schemaData}>
  <nav class="breadcrumbs">
    <a href="/">Home</a> &gt; 
    <a href={`/brands/${slugify(model.goldBrand.canonicalName)}`}>{model.goldBrand.canonicalName}</a> &gt; 
    {model.goldProductLine ? (
       <a href={`/product/${slugify(model.goldBrand.canonicalName)}/${lineSlug}`}>{lineDisplay}</a>
    ) : (
       lineDisplay
    )} &gt; 
    {model.canonicalName}
  </nav>
  
  <header style="margin-bottom: 2rem;">
    <h1>{model.goldBrand.canonicalName} {model.canonicalName}</h1>
    <div style="display: flex; gap: 1rem; align-items: center; margin-bottom: 1.5rem;">
      <span class="score-badge">BIFL Score: {model.avgSentiment > 0 ? "Positive" : "Pending"}</span>
      <span style="color: var(--bifl-body-text);">{model.mentionCount} Verified Mentions</span>
    </div>
    <!-- Tier 1 Affiliate Placeholder -->
    <a href={`https://amazon.com/s?k=${encodeURIComponent(model.goldBrand.canonicalName + ' ' + model.canonicalName)}&tag=biflscore-20`} class="cta-button" target="_blank" rel="nofollow noopener">Check Price on Amazon</a>
  </header>

  <div style="display: flex; gap: 2rem; flex-wrap: wrap;">
    <section style="flex: 2; min-width: 300px;">
      <h2>Community Extraction</h2>
      
      <div class="data-grid" style="grid-template-columns: 1fr 1fr; margin-bottom: 1rem;">
        <div class="bifl-card">
          <h4 style="margin-top: 0; margin-bottom: 0.5rem; color: #888; font-size: 0.875rem;">Average Price Paid</h4>
          <span style="font-size: 2rem; font-weight: 700; color: var(--bifl-charcoal);">{avgPrice ? `$${avgPrice}` : 'Unknown'}</span>
        </div>
        <div class="bifl-card">
          <h4 style="margin-top: 0; margin-bottom: 0.5rem; color: #888; font-size: 0.875rem;">Average Ownership</h4>
          <span style="font-size: 2rem; font-weight: 700; color: var(--bifl-charcoal);">{avgDuration ? `${avgDuration} Years` : 'Unknown'}</span>
        </div>
      </div>
      
      {quotes.length > 0 && (
        <article>
          <h3>What Users Say</h3>
          <div style="display: flex; flex-direction: column; gap: 1rem;">
            {quotes.map((q: string) => <div class="bifl-card" style="font-style: italic;">"{q}"</div>)}
          </div>
        </article>
      )}

      {caveats.length > 0 && (
        <article style="margin-top: 2rem;">
          <h3 style="color: var(--bifl-accent-rust);">Common Flaws &amp; Caveats</h3>
          <div class="bifl-card" style="border-left: 4px solid var(--bifl-accent-rust);">
            <ul style="margin: 0; padding-left: 1rem;">
              {caveats.map((c: string) => <li>{c}</li>)}
            </ul>
          </div>
        </article>
      )}
    </section>
    
    {siblingModels.length > 0 && (
      <aside style="flex: 1; min-width: 250px;">
        <div class="bifl-card">
          <h3 style="margin-top: 0;">Other Models in this Line</h3>
          <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.75rem;">
            {siblingModels.map((sibling: any) => (
               <li style="border-bottom: 1px solid var(--bifl-border-color); padding-bottom: 0.75rem;">
                 <a href={`/product/${slugify(model.goldBrand.canonicalName)}/${slugify(model.goldProductLine!.canonicalName)}/${slugify(sibling.canonicalName)}`}>
                   {sibling.canonicalName}
                 </a>
               </li>
            ))}
          </ul>
        </div>
      </aside>
    )}
  </div>
</BaseLayout>
