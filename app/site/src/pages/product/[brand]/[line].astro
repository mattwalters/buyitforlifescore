---
import { prisma as db } from "@mono/db";
import { slugify } from "../../../utils/slugify";

import BaseLayout from '../../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const productLines = await db.goldProductLine.findMany({
    include: {
      goldBrand: true,
      products: {
        orderBy: { mentionCount: 'desc' }
      },
      mentions: true
    }
  });

  return productLines.map(line => {
    // Aggregations for generic mentions tied directly to the Product Line
    const validPrices = line.mentions.map(m => m.acquiredPrice).filter(p => p !== null) as number[];
    const avgPrice = validPrices.length ? (validPrices.reduce((a,b) => a+b, 0) / validPrices.length).toFixed(2) : null;
    
    const validDurations = line.mentions.map(m => m.ownershipDurationMonths).filter(p => p !== null) as number[];
    const avgDuration = validDurations.length ? (validDurations.reduce((a,b) => a+b, 0) / validDurations.length / 12).toFixed(1) : null;

    const caveats = line.mentions.map(m => m.flawOrCaveat).filter(f => f && f.length > 5).slice(0, 3);
    const quotes = line.mentions.map(m => m.quote).filter(q => q && q.length > 5).slice(0, 3);

    return {
      params: { 
        brand: slugify(line.goldBrand.canonicalName),
        line: slugify(line.canonicalName) 
      },
      props: { 
        line,
        avgPrice,
        avgDuration,
        caveats,
        quotes
      },
    };
  });
}

const { line, avgPrice, avgDuration, caveats, quotes } = Astro.props;
---

<BaseLayout title={`${line.goldBrand.canonicalName} ${line.canonicalName} Reviews & Versions`}>
  <nav class="breadcrumbs">
    <a href="/">Home</a> &gt; 
    <a href={`/brands/${slugify(line.goldBrand.canonicalName)}`}>{line.goldBrand.canonicalName}</a> &gt; 
    {line.canonicalName}
  </nav>
  
  <header>
    <h1>{line.goldBrand.canonicalName} {line.canonicalName}</h1>
    <p>
      <span class="score-badge">Generic Series BIFL Score: {line.avgSentiment > 0 ? "Positive" : "Pending"}</span> 
      <span style="margin-left: 1rem; color: var(--bifl-body-text);">{line.mentionCount} Total Mentions</span>
    </p>
  </header>

  <div style="display: flex; gap: 2rem; flex-wrap: wrap; margin-top: 2rem;">
    <section style="flex: 1; min-width: 300px;">
      <h2>Verified Community Experience</h2>
      <div class="bifl-card">
        <ul style="list-style: none; padding: 0; margin: 0;">
          <li style="margin-bottom: 0.5rem;"><strong>Average Price Paid:</strong> {avgPrice ? `$${avgPrice}` : 'Unknown'}</li>
          <li><strong>Average Ownership:</strong> {avgDuration ? `${avgDuration} Years` : 'Unknown'}</li>
        </ul>
      </div>
      
      {quotes.length > 0 && (
        <article style="margin-top: 2rem;">
          <h3>What Users Say</h3>
          <div style="display: flex; flex-direction: column; gap: 1rem;">
            {quotes.map((q: string) => <div class="bifl-card" style="font-style: italic;">"{q}"</div>)}
          </div>
        </article>
      )}

      {caveats.length > 0 && (
        <article style="margin-top: 2rem;">
          <h3 style="color: var(--bifl-accent-rust);">Common Flaws &amp; Caveats</h3>
          <ul style="list-style: square;">
            {caveats.map((c: string) => <li>{c}</li>)}
          </ul>
        </article>
      )}
    </section>

    {line.products.length > 0 && (
      <section style="flex: 2; min-width: 300px;">
        <h2>Specific Model Directory</h2>
        <table>
          <thead>
            <tr>
              <th>Model</th>
              <th>Mentions</th>
              <th>Durability Score</th>
              <th>Action</th>
            </tr>
          </thead>
          <tbody>
            {line.products.map((product: any) => (
              <tr>
                <td style="font-weight: 500;">{product.canonicalName}</td>
                <td>{product.mentionCount}</td>
                <td>{product.avgSentiment > 0 ? "High" : "Average"}</td>
                <td>
                  <a href={`/product/${slugify(line.goldBrand.canonicalName)}/${slugify(line.canonicalName)}/${slugify(product.canonicalName)}`} class="button" style="padding: 0.4rem 0.8rem; font-size: 0.875rem;">
                    Read Reviews
                  </a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </section>
    )}
  </div>
</BaseLayout>
