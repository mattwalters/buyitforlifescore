---
import { prisma as db } from "@mono/db";
import { slugify } from "../../utils/slugify";

import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const categories = await db.goldCategory.findMany({
    include: {
      productLines: {
        include: { goldBrand: true },
        orderBy: { mentionCount: 'desc' }
      }
    }
  });

  const allCategories = await db.goldCategory.findMany();

  return categories.map(cat => {
    return {
      params: { category: slugify(cat.canonicalName) },
      props: { 
        category: cat,
        relatedCategories: allCategories.filter(c => c.id !== cat.id).slice(0, 5)
      },
    };
  });
}

const { category, relatedCategories } = Astro.props;
---

<BaseLayout title={`Best ${category.canonicalName}`}>
  <nav class="breadcrumbs">
    <a href="/">Home</a> &gt; Category &gt; {category.canonicalName}
  </nav>

  <header>
    <h1>The Best {category.canonicalName}</h1>
    <p>Ranked models engineered for extreme durability and lifespan.</p>
  </header>
  
  <section>
    <h2>Top Ranked Ecosystems</h2>
    <div class="data-grid">
      {category.productLines.map((line: any) => (
        <a href={`/product/${slugify(line.goldBrand.canonicalName)}/${slugify(line.canonicalName)}`} class="bifl-card" style="text-decoration: none;">
          <h3 style="margin-top: 0; color: var(--bifl-charcoal);">{line.goldBrand.canonicalName} {line.canonicalName}</h3>
          <span class="score-badge">{line.mentionCount} Mentions</span>
        </a>
      ))}
    </div>
  </section>

  {relatedCategories.length > 0 && (
    <aside style="margin-top: 4rem;">
      <h3>Related Categories</h3>
      <div style="display: flex; gap: 1rem; flex-wrap: wrap;">
        {relatedCategories.map((rc: any) => (
          <a href={`/category/${slugify(rc.canonicalName)}`} class="button" style="background-color: var(--bifl-charcoal);">{rc.canonicalName}</a>
        ))}
      </div>
    </aside>
  )}
</BaseLayout>
