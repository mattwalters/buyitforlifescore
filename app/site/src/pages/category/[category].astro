---
import { prisma as db } from "@mono/db";
import { slugify } from "../../utils/slugify";
import BaseLayout from '../../layouts/BaseLayout.astro';
import TufteSparkline from '../../components/TufteSparkline.astro';
import ComparativeRadar from '../../components/charts/ComparativeRadar.astro';
import ComparativeLifecycleChart from '../../components/charts/ComparativeLifecycleChart.astro';
import RadarStatBlock from '../../components/charts/RadarStatBlock.astro';

export async function getStaticPaths() {
  const categories = await db.goldCategory.findMany();
  return categories.map(cat => ({
    params: { category: slugify(cat.canonicalName) },
    props: { categoryId: cat.id, canonicalName: cat.canonicalName },
  }));
}

const { categoryId, canonicalName } = Astro.props;

// Fetch the Top 5 Product Lines for this category, including the last 10 years of Mentions for timeline processing
const category = await db.goldCategory.findUnique({
  where: { id: categoryId },
  include: {
    productLines: {
      include: {
        goldBrand: true,
        mentions: {
          include: { 
            submission: { select: { postedAt: true } },
            comment: { select: { postedAt: true } }
          }
        }
      }
    }
  }
});

const allLines = category?.productLines || [];

const calculateBiflScore = (line: any) => {
  const mentions = line.mentions || [];
  const total = mentions.length;
  if (total < 3) return 0; // Statistical confidence gate

  // 1. Base Sentiment Volume (60% Weight)
  let pos = 0; let neg = 0;
  mentions.forEach((m: any) => {
     if (m.sentiment === 'POSITIVE') pos++;
     if (m.sentiment === 'NEGATIVE') neg++;
  });
  const rawSentiment = Math.max(0, (pos - neg) / total);
  const sentimentPoints = rawSentiment * 60; // Max 60 points

  // 2. Core 5 Metrics Overlap (40% Weight)
  let c5 = { durability: 0, repairability: 0, warranty: 0 };
  let c5c = { durability: 0, repairability: 0, warranty: 0 };
  const scoreMap: any = { "POSITIVE": 100, "NEUTRAL": 50, "NEGATIVE": 0 };
  
  mentions.forEach((m: any) => {
     if (m.durability) { c5c.durability++; c5.durability += scoreMap[m.durability] ?? 50; }
     if (m.repairability) { c5c.repairability++; c5.repairability += scoreMap[m.repairability] ?? 50; }
     if (m.warranty) { c5c.warranty++; c5.warranty += scoreMap[m.warranty] ?? 50; }
  });

  const dScore = c5c.durability > 0 ? c5.durability / c5c.durability : 50;
  const rScore = c5c.repairability > 0 ? c5.repairability / c5c.repairability : 50;
  const wScore = c5c.warranty > 0 ? c5.warranty / c5c.warranty : 50;
  
  // Weights: Durability 20%, Repairability 10%, Warranty 10%
  const core5Points = (dScore * 0.20) + (rScore * 0.10) + (wScore * 0.10);

  // 3. The Consistency Multiplier (Time Bonus)
  const years = new Set(mentions.map((m: any) => {
    const d = m.submission?.postedAt || m.comment?.postedAt;
    return d ? new Date(d).getFullYear() : null;
  }).filter(Boolean));
  
  const yearsActive = years.size;
  let consistencyBonus = 0.80; // Penalty
  if (yearsActive >= 10) consistencyBonus = 1.15; // Legacy Bonus
  else if (yearsActive >= 5) consistencyBonus = 1.00; // Baseline
  else if (yearsActive >= 3) consistencyBonus = 0.95;
  else if (yearsActive >= 2) consistencyBonus = 0.90;

  return Math.min(99, Math.round((sentimentPoints + core5Points) * consistencyBonus));
};

const scoredLines = allLines.map((line: any) => ({
  ...line,
  biflScore: calculateBiflScore(line)
}));

// Strictly rank the entire category by the mathematical core, returning only the proven top 5
const topLines = scoredLines
  .sort((a, b) => {
    if (b.biflScore === a.biflScore) return (b.mentionCount || 0) - (a.mentionCount || 0);
    return b.biflScore - a.biflScore;
  })
  .slice(0, 5);

const champion = topLines[0];
const contenders = topLines.slice(1);

// Math: Build the D3 Tufte Timeline Series from raw DB sentiment
const colorPalette = ['#eab308', '#94a3b8', '#cd7f32', '#3b82f6', '#10b981']; // Distinct Gold, Silver, Bronze
const currentYearObj = new Date().getFullYear();

const timelineSeries = topLines.map((line, i) => {
  const yearBuckets: Record<number, { count: number, pos: number }> = {};
  
  line.mentions.forEach(m => {
    // Determine the original post date using either submission or comment relations
    const actualDate = m.submission?.postedAt || m.comment?.postedAt;
    if (!actualDate) return;
    
    const year = new Date(actualDate).getFullYear();
    // Filter out anything older than 10 years
    if (year < currentYearObj - 10) return;

    if (!yearBuckets[year]) yearBuckets[year] = { count: 0, pos: 0 };
    yearBuckets[year].count++;
    if (m.sentiment === 'POSITIVE') yearBuckets[year].pos++;
  });

  const data = Object.entries(yearBuckets)
    .filter(([_, stats]) => stats.count >= 2) // Require at least 2 mentions in a year to prevent statistical noise
    .map(([year, stats]) => ({
       year: parseInt(year, 10),
       score: Math.round((stats.pos / stats.count) * 100)
    }));
  
  return {
    id: line.id,
    label: `${line.goldBrand.canonicalName} ${line.canonicalName}`,
    color: colorPalette[i] || '#64748b',
    data
  };
});

// Calculate Comparative Radar Stats (Max 3 overlaps)
const radarSeries = topLines.slice(0, 3).map((line, i) => {
  let rc = { durability: 0, repairability: 0, maintenance: 0, value: 0, warranty: 0 };
  let tc = { durability: 0, repairability: 0, maintenance: 0, value: 0, warranty: 0 };
  const scoreMap: any = { "POSITIVE": 10, "NEUTRAL": 5, "NEGATIVE": 0 };

  line.mentions.forEach((m: any) => {
     if (m.durability) { tc.durability++; rc.durability += scoreMap[m.durability] ?? 5; }
     if (m.repairability) { tc.repairability++; rc.repairability += scoreMap[m.repairability] ?? 5; }
     if (m.maintenance) { tc.maintenance++; rc.maintenance += scoreMap[m.maintenance] ?? 5; }
     if (m.value) { tc.value++; rc.value += scoreMap[m.value] ?? 5; }
     if (m.warranty) { tc.warranty++; rc.warranty += scoreMap[m.warranty] ?? 5; }
  });

  return {
    label: `${line.goldBrand.canonicalName} ${line.canonicalName}`,
    color: colorPalette[i],
    rank: i + 1,
    durability: tc.durability > 0 ? rc.durability / tc.durability : 5,
    repairability: tc.repairability > 0 ? rc.repairability / tc.repairability : 5,
    maintenance: tc.maintenance > 0 ? rc.maintenance / tc.maintenance : 5,
    value: tc.value > 0 ? rc.value / tc.value : 5,
    warranty: tc.warranty > 0 ? rc.warranty / tc.warranty : 5,
  };
});

// Calculate metrics individually for the isolated RadarStatBlock
const getRadarSingular = (line: any) => {
  let rc = { durability: 0, repairability: 0, maintenance: 0, value: 0, warranty: 0 };
  let tc = { durability: 0, repairability: 0, maintenance: 0, value: 0, warranty: 0 };
  const scoreMap: any = { "POSITIVE": 10, "NEUTRAL": 5, "NEGATIVE": 0 };

  line.mentions.forEach((m: any) => {
     if (m.durability) { tc.durability++; rc.durability += scoreMap[m.durability] ?? 5; }
     if (m.repairability) { tc.repairability++; rc.repairability += scoreMap[m.repairability] ?? 5; }
     if (m.maintenance) { tc.maintenance++; rc.maintenance += scoreMap[m.maintenance] ?? 5; }
     if (m.value) { tc.value++; rc.value += scoreMap[m.value] ?? 5; }
     if (m.warranty) { tc.warranty++; rc.warranty += scoreMap[m.warranty] ?? 5; }
  });
  
  return {
    durability: tc.durability > 0 ? rc.durability / tc.durability : 5,
    repairability: tc.repairability > 0 ? rc.repairability / tc.repairability : 5,
    maintenance: tc.maintenance > 0 ? rc.maintenance / tc.maintenance : 5,
    value: tc.value > 0 ? rc.value / tc.value : 5,
    warranty: tc.warranty > 0 ? rc.warranty / tc.warranty : 5,
  };
};

const comparativeLifecycleSeries = topLines.slice(0, 3).map((line, i) => {
  const yearBuckets: Record<number, { count: number, pos: number }> = {};
  
  line.mentions.forEach((m: any) => {
    const actualDate = m.submission?.postedAt || m.comment?.postedAt;
    if (!actualDate) return;
    
    const year = new Date(actualDate).getFullYear();
    if (year < currentYearObj - 10) return;

    if (!yearBuckets[year]) yearBuckets[year] = { count: 0, pos: 0 };
    yearBuckets[year].count++;
    if (m.sentiment === 'POSITIVE') yearBuckets[year].pos++;
  });

  const data = Object.entries(yearBuckets)
    .filter(([_, stats]) => stats.count >= 1) // Allow 1 mention to plot in dev/sparse data environments
    .map(([year, stats]) => ({
       period: year.toString(), // Map calendar year to "period" axis point
       score: Math.round((stats.pos / stats.count) * 100)
    }));
  
  return {
    id: line.id,
    label: `${line.goldBrand.canonicalName} ${line.canonicalName}`,
    color: colorPalette[i] || '#64748b',
    rank: i + 1,
    data: data.sort((a,b) => parseInt(a.period) - parseInt(b.period)) // Ensure chronological order
  };
});

const getFlaws = (line: any) => {
  const allFlaws = line.mentions.map((m: any) => m.flawOrCaveat).filter(Boolean) as string[];
  return allFlaws.sort(() => 0.5 - Math.random()).slice(0, 3);
};

// Calculate total mentions across the category to show statistical weight
const totalCategoryMentions = topLines.reduce((acc, line) => acc + line.mentionCount, 0);

---

<BaseLayout title={`Best ${canonicalName} (Ranked)`}>
  
  <!-- Breadcrumb Navigation -->
  <nav class="breadcrumbs">
    <a href="/">Home</a> &gt; Category &gt; {canonicalName}
  </nav>

  <header style="margin-bottom: 0;">
    <h1 style="font-size: 2.5rem; margin-bottom: 0.5rem; color: var(--bifl-charcoal);">The Best {canonicalName}</h1>
    <p style="color: var(--bifl-text-muted); font-size: 1.1rem; text-wrap: balance; margin-bottom: 0;">
      The definitive buy-it-for-life leaderboard. Ranked objectively using <strong>{totalCategoryMentions.toLocaleString()} organic field-reports</strong> aggregated across Reddit.
    </p>
  </header>

    <!-- The Category Comparative Radar Chart -->
    {radarSeries.length > 0 && (
      <div style="margin-bottom: 3rem;">
        <div style="margin-top: 2rem; display: flex; flex-wrap: wrap; gap: 4rem; justify-content: space-between; align-items: flex-start;">
           <div style="flex: 1; min-width: 300px;">
             <h2 style="font-size: 1.5rem; color: var(--bifl-charcoal); margin-bottom: 0.5rem;">Competitive Overlap</h2>
             <p style="color: var(--bifl-text-muted); font-size: 1rem; margin-top: 0; margin-bottom: 2rem;">
               Compare the top products against 5 core longevity metrics.
             </p>
             <ComparativeRadar series={radarSeries} size={300} hideLegend={true} />
           </div>
           
           <div style="flex: 2; min-width: 400px; max-width: 800px;">
             <h2 style="font-size: 1.5rem; color: var(--bifl-charcoal); margin-bottom: 0.5rem;">Historical Leaderboard Trajectory</h2>
             <p style="color: var(--bifl-text-muted); font-size: 1rem; margin-top: 0; margin-bottom: 2rem;">
               Average positive sentiment (%) grouped by organic post date over the last decade.
             </p>
             <ComparativeLifecycleChart series={comparativeLifecycleSeries} width={600} height={350} hideLegend={true} />
           </div>
        </div>

        {/* Global Shared Legend */}
        <div style="margin-top: 1rem; padding-top: 1rem; border-top: 1px solid #e2e8f0; padding-bottom: 0.5rem;">
          <div style="display: flex; justify-content: space-between; align-items: center; width: 100%; flex-wrap: wrap; gap: 1.5rem; padding-left: 2rem; padding-right: 2rem;">
            {comparativeLifecycleSeries.map((s) => {
               const getRankIcon = (rank?: number) => {
                 if (rank === 1) return "🥇";
                 if (rank === 2) return "🥈";
                 if (rank === 3) return "🥉";
                 if (rank === 4) return "4️⃣";
                 if (rank === 5) return "5️⃣";
                 return "";
               };

               return (
                 <div class="flex items-center gap-2 text-[15px] text-slate-700 font-medium whitespace-nowrap">
                   <span style={`display: inline-block; width: 24px; height: 4px; border-radius: 2px; background-color: ${s.color}; transform: translateY(-3px);`}></span>
                   <span>{getRankIcon(s.rank)} {s.label}</span>
                 </div>
               );
            })}
          </div>
        </div>
      </div>
    )}
    
  <section class="leaderboard-grid">
    <!-- GOLD RANK (#1) permanently expanded -->
    {champion && (() => {
      const flaws = getFlaws(champion);
      const radarData = getRadarSingular(champion);
      const timelineData = timelineSeries.find(s => s.id === champion.id);
      
      return (
      <article class="champion-card" style="border: 2px solid #eab308; border-radius: 12px; padding: 2rem; margin-bottom: 3rem; background: linear-gradient(180deg, rgba(234, 179, 8, 0.05) 0%, transparent 100%); position: relative;">
        <div style="position: absolute; top: -16px; left: 24px; background: #eab308; color: #fff; padding: 4px 16px; border-radius: 999px; font-weight: bold; font-size: 0.9rem; display: flex; align-items: center; gap: 6px;">
          🥇 Category Leader
        </div>
        
        <!-- Native grid split for content vs radar -->
        <div class="champion-inner-grid" style="display: grid; grid-template-columns: 1fr 300px; gap: 2rem; align-items: start;">
          <div>
            <div style="display: flex; align-items: flex-start; justify-content: space-between; gap: 1rem;">
              <h2 style="font-size: 2.2rem; margin: 0; color: var(--bifl-charcoal); line-height: 1.1;">
                <a href={`/product/${slugify(champion.goldBrand.canonicalName)}/${slugify(champion.canonicalName)}`} style="text-decoration: none; color: inherit;">
                  {champion.goldBrand.canonicalName} {champion.canonicalName}
                </a>
              </h2>
              
              <!-- Scientific BIFL Score Authority Badge -->
              <a href="/methodology" title="View our data-science methodology" style="flex-shrink: 0; text-decoration: none; display: flex; flex-direction: column; align-items: center; justify-content: center; background: #fff; border: 3px solid #eab308; border-radius: 16px; width: 80px; height: 80px; box-shadow: 0 10px 15px -3px rgb(234 179 8 / 0.15), 0 4px 6px -4px rgb(234 179 8 / 0.1);">
                <span style="font-size: 2rem; font-weight: 900; color: #ca8a04; line-height: 1; font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;">{champion.biflScore}</span>
                <span style="font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: #a16207; opacity: 0.9; margin-top: 2px;">BIFL Score</span>
              </a>
            </div>
            
            <div style="margin-top: 0.5rem; display: flex; gap: 1rem; align-items: center;">
              <span class="score-badge" style="background: rgba(234, 179, 8, 0.1); color: #ca8a04; border-color: rgba(234, 179, 8, 0.2);">
                {champion.mentionCount.toLocaleString()} Mentions
              </span>
              
              <!-- Localized Timeline Sparkline for the Champion -->
              {timelineData && timelineData.data.length > 1 && (
                <div style="padding-left: 1rem; border-left: 1px solid var(--bifl-border);">
                  <TufteSparkline data={timelineData.data} color={timelineData.color} />
                </div>
              )}
            </div>

            {flaws.length > 0 && (
              <div style="margin-top: 2rem; background: #fff; border: 1px solid var(--bifl-border); border-radius: 8px; padding: 1.5rem;">
                <h4 style="font-size: 0.9rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--bifl-text-muted); margin-top: 0;">Known Caveats & Warnings</h4>
                <ul style="margin: 0; padding-left: 1.2rem; font-size: 0.95rem; color: #475569;">
                  {flaws.map(flaw => (
                    <li style="margin-bottom: 0.5rem;">"{flaw}"</li>
                  ))}
                </ul>
                <p style="font-size: 0.8rem; color: #94a3b8; margin-top: 1rem; margin-bottom: 0;">* Sourced directly from field-reports to provide balanced context</p>
              </div>
            )}
          </div>
          
          <!-- Mini Sub-Radar Chart for the Champion -->
          <div style="background: #fff; border-radius: 8px; padding: 1rem; border: 1px solid var(--bifl-border); display: flex; align-items: center; justify-content: center;">
             <RadarStatBlock {...radarData} size={250} />
          </div>
        </div>
      </article>
      );
    })()}

    <!-- CONTENDERS (Ranks 2-5) -->
    {contenders.length > 0 && (
      <div style="margin-bottom: 6rem;">
        <h3 style="font-size: 1.5rem; color: var(--bifl-charcoal); border-bottom: 2px solid var(--bifl-border); padding-bottom: 0.5rem;">The Contenders</h3>
        
        <div style="display: flex; flex-direction: column; gap: 1rem; margin-top: 1.5rem;">
          {contenders.map((line, idx) => {
            const rankMap = ['🥈 Rank 2', '🥉 Rank 3', '4️⃣ Rank 4', '5️⃣ Rank 5'];
            const rankIcon = rankMap[idx] || '🔹 Contender';
            
            const flaws = getFlaws(line);
            const radarData = getRadarSingular(line);
            const timelineData = timelineSeries.find(s => s.id === line.id);

            return (
              <details class="contender-accordion group" style="border: 1px solid var(--bifl-border); border-radius: 8px; background: #fff; overflow: hidden; font-family: inherit;">
                
                {/* 1. The Summary Bar (Collapsed View) */}
                <summary style="display: flex; align-items: center; justify-content: space-between; padding: 1rem 1.5rem; cursor: pointer; user-select: none; list-style: none;">
                  <div style="display: flex; align-items: center; gap: 1.5rem;">
                    <span style="font-size: 0.9rem; font-weight: bold; color: var(--bifl-text-muted); min-width: 80px;">{rankIcon}</span>
                    <h3 style="margin: 0; font-size: 1.2rem; color: var(--bifl-charcoal);">{line.goldBrand.canonicalName} {line.canonicalName}</h3>
                  </div>
                  
                  <div style="display: flex; align-items: center; gap: 2rem;">
                    <!-- Localized Inline Sparkline -->
                    {timelineData && timelineData.data.length > 1 && (
                      <div class="hide-on-mobile" style="opacity: 0.8;">
                        <TufteSparkline data={timelineData.data} color={timelineData.color} />
                      </div>
                    )}
                    <span class="score-badge">{line.mentionCount.toLocaleString()} Mentions</span>
                    <!-- CSS Caret for indication -->
                    <span class="icon-caret" style="color: var(--bifl-text-muted); transition: transform 0.2s;">▼</span>
                  </div>
                </summary>
                
                {/* 2. The Expanded Deep-Dive Area */}
                <div style="padding: 2rem; border-top: 1px solid var(--bifl-border); background: #f8fafc;">
                  <div style="display: grid; grid-template-columns: 1fr 250px; gap: 2rem;">
                    <div>
                      {flaws.length > 0 ? (
                        <div style="background: #fff; border: 1px solid var(--bifl-border); border-radius: 8px; padding: 1.5rem;">
                          <h4 style="font-size: 0.9rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--bifl-text-muted); margin-top: 0;">Known Caveats & Warnings</h4>
                          <ul style="margin: 0; padding-left: 1.2rem; font-size: 0.95rem; color: #475569;">
                            {flaws.map(flaw => (
                              <li style="margin-bottom: 0.5rem;">"{flaw}"</li>
                            ))}
                          </ul>
                        </div>
                      ) : (
                        <p style="color: var(--bifl-text-muted);">No significant warnings found for this line.</p>
                      )}
                      
                      <div style="margin-top: 1.5rem;">
                         <a href={`/product/${slugify(line.goldBrand.canonicalName)}/${slugify(line.canonicalName)}`} class="button" style="background-color: var(--bifl-charcoal); color: white; display: inline-block;">View Full Durability Report</a>
                      </div>
                    </div>
                    
                    {/* The Contender's Radar Chart */}
                    <div style="background: #fff; border-radius: 8px; padding: 1rem; border: 1px solid var(--bifl-border); display: flex; align-items: center; justify-content: center;">
                       <RadarStatBlock {...radarData} size={220} />
                    </div>
                  </div>
                </div>
              </details>
            )
          })}
        </div>
      </div>
    )}
  </section>
</BaseLayout>

<style>
  /* Base Accordion Interactions */
  .contender-accordion {
    transition: box-shadow 0.2s ease;
  }
  .contender-accordion:hover {
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
  }
  
  /* Disable default ugly summary triangle */
  .contender-accordion summary::-webkit-details-marker {
    display: none;
  }
  
  /* Animate the caret when opened */
  .contender-accordion[open] summary .icon-caret {
    transform: rotate(180deg);
  }

  /* Responsive layout tweaks */
  @media (max-width: 800px) {
    .champion-inner-grid {
      grid-template-columns: 1fr !important;
    }
    .hide-on-mobile {
      display: none;
    }
    .contender-accordion > div > div {
       grid-template-columns: 1fr !important;
    }
  }
</style>
