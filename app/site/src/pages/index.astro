---
import { prisma as db } from "@mono/db";
import { slugify } from "../utils/slugify";

import BaseLayout from '../layouts/BaseLayout.astro';

const departments = await db.goldDepartment.findMany({
  orderBy: { canonicalName: 'asc' }
});

const categories = await db.goldCategory.findMany({
  orderBy: { canonicalName: 'asc' }
});
---

<BaseLayout title="Buy It For Life Data & Rankings">
  <section>
    <h1>The Heritage Ledger</h1>
    <p>Discover products engineered to last a lifetime, ranked by true community experience rather than marketing copy.</p>
  </section>

  <section>
    <h2>Top Categories</h2>
    <div class="data-grid">
      {categories.map((cat) => (
        <a href={`/category/${slugify(cat.canonicalName)}`} class="bifl-card">
          <h3 style="margin: 0; color: var(--bifl-brand-green);">{cat.canonicalName}</h3>
        </a>
      ))}
    </div>
  </section>

  <section style="display: flex; gap: 2rem;">
    <div style="flex: 1;">
      <h2>Departments</h2>
      <ul style="list-style: square;">
        {departments.map((dept) => (
          <li>
            <a href={`/department/${slugify(dept.canonicalName)}`}>
              {dept.canonicalName}
            </a>
          </li>
        ))}
      </ul>
    </div>
    <div style="flex: 1;">
      <h2>Explore</h2>
      <ul style="list-style: square;">
        <li><a href="/brands">Master Brands Directory</a></li>
      </ul>
    </div>
  </section>
</BaseLayout>
